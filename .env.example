# Project
PROJECT_NAME=SDModels API
VERSION=1.0.0
API_V1_STR=/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sdmodels

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=private_key.pem
JWT_PUBLIC_KEY_PATH=public_key.pem
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# File Storage
STORAGE_BACKEND=s3  # Options: s3, opendrive

# S3/CloudFlare R2 Storage
S3_BUCKET_NAME=sdmodels-storage
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_REGION=us-east-1
CDN_URL=https://cdn.sdmodels.com

# OpenDrive Storage (if using STORAGE_BACKEND=opendrive)
OPENDRIVE_USERNAME=your-opendrive-username-or-email
OPENDRIVE_PASSWORD=your-opendrive-password
OPENDRIVE_PARTNER_ID=OpenDrive

# Upload Limits (in bytes)
MAX_MODEL_SIZE=104857600
MAX_IMAGE_SIZE=10485760
MAX_AVATAR_SIZE=2097152

# Payment - Paystack (Fiat/NGN)
PAYSTACK_SECRET_KEY=sk_test_319f8f0b59d2b99fb12e01d6956fbcf8cd45dd1d
PAYSTACK_PUBLIC_KEY=pk_test_62d6a1c731ffc99c8c9aa7f9eb44a90253afd9c8
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Payment - NOWPayments (Crypto)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_key

# Currency Exchange Rate API (Optional - for live rates)
# Get free API key from https://www.exchangerate-api.com/
# If not set, will use fallback rates (1540 NGN = 1 USD)
EXCHANGE_RATE_API_KEY=

# Payment Configuration
PLATFORM_FEE_PERCENTAGE=7.5
MIN_WITHDRAWAL_AMOUNT=5000
MAX_WITHDRAWAL_AMOUNT=10000000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@sdmodels.com
SMTP_PASSWORD=your-email-password
EMAILS_FROM_EMAIL=noreply@sdmodels.com
EMAILS_FROM_NAME=SDModels

# OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Admin
ADMIN_EMAIL=admin@sdmodels.com
ADMIN_PASSWORD=change-this-secure-admin-password

# Security
SECRET_KEY=your-super-secret-key-for-general-encryption
